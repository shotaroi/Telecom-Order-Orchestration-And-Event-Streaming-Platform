{
  "title": "Telecom Order Platform",
  "panels": [
    {
      "id": 1,
      "title": "Orders Created",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "rate(orders_created_total[5m])", "legendFormat": "orders/s"}]
    },
    {
      "id": 2,
      "title": "Orders Failed",
