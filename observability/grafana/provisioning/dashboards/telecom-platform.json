      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "orchestrator_orders_failed_total", "legendFormat": "failed"}]
    },
    {
      "id": 3,
      "title": "Provisioning Duration p95",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "histogram_quantile(0.95, rate(provisioning_duration_seconds_bucket[5m]))", "legendFormat": "p95"}]
    }
  ],
  "schemaVersion": 38,
  "version": 1
